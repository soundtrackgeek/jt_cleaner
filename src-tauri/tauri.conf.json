{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luna Clean",
  "version": "0.8.0",
  "identifier": "com.soundtrackgeek.lunaclean",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "Luna Clean",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "shortDescription": "A careful, AI-assisted Windows storage cleaner",
    "longDescription": "Luna Clean finds reclaimable storage, explains file age and risk, and helps you clean with confidence.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzNkVCNEFCQjJBQkEyNTcKUldSWG9xdXlxN1J1ZzRDczRCL1hFLzFGcVU0dXgxUGQwTndnZjJ1a1lzREpZQnVnaGFCMkRMdS8K",
      "endpoints": [
        "https://github.com/soundtrackgeek/jt_cleaner/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
